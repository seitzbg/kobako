# App connection string (used by the SvelteKit app / Drizzle).
DATABASE_URL=postgres://kobako:kobako@localhost:5432/kobako

# Postgres container credentials (consumed by docker-compose.yml).
# Copy this file to .env and set a real POSTGRES_PASSWORD for any non-local deploy.
POSTGRES_USER=kobako
POSTGRES_PASSWORD=kobako
POSTGRES_DB=kobako
